rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, isActive, isUpgraded, anonymousName
    //
    // Collection: questions
    // Fields: text, options, correctOption, category, justification, createdAt
    //
    // Collection: simulations
    // Fields: userId, score, totalQuestions, date, anonymousName
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "8I83FFoO4ASDc1vh2rN8fBN8AzE2" ||
        ('email' in request.auth.token && (request.auth.token.email == "allanjonesms@gmail.com" || request.auth.token.email == "herek.alexandre@gmail.com")) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isActive', 'isUpgraded', 'anonymousName', 'photoURL']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.isActive is bool &&
             data.isUpgraded is bool &&
             data.anonymousName is string &&
             data.photoURL is string &&
             (!('upgradedAt' in data) || data.upgradedAt == null || data.upgradedAt is timestamp) &&
             (!('lastPaymentId' in data) || data.lastPaymentId is string);
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['text', 'options', 'correctOption']) &&
             data.text is string &&
             data.options is list &&
             data.options.size() >= 4 &&
             data.correctOption is int &&
             data.correctOption >= 0 && data.correctOption <= 4 &&
             (!('category' in data) || data.category is string) &&
             (!('law' in data) || data.law is string) &&
             (!('justification' in data) || data.justification is string);
    }

    function isValidSimulation(data) {
      return data.keys().hasAll(['userId', 'score', 'totalQuestions', 'date', 'anonymousName']) &&
             data.userId == request.auth.uid &&
             data.score is int &&
             data.totalQuestions is int &&
             data.anonymousName is string;
    }

    function isValidQuestionError(data) {
      return data.keys().hasAll(['questionId', 'questionText', 'userId', 'userEmail', 'description', 'status', 'createdAt', 'updatedAt']) &&
             data.questionId is string &&
             data.questionText is string &&
             data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.description is string &&
             data.description.size() > 0 &&
             data.description.size() < 2000 &&
             data.status in ['pending', 'resolved'];
    }

    // Rules
    match /users {
      allow list: if isAdmin();
      match /{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
        allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
        allow delete: if isAdmin();
      }
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidQuestion(request.resource.data);
      allow delete: if isAdmin();
    }

    match /simulations/{simulationId} {
      allow read: if isAuthenticated(); // Allowed for ranking
      allow create: if isAuthenticated() && isValidSimulation(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /active_simulations {
      allow read: if isAdmin();
      match /{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /question_errors/{errorId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidQuestionError(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
