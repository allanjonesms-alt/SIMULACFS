{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isActive": { "type": "boolean" },
        "isUpgraded": { "type": "boolean" },
        "anonymousName": { "type": "string" }
      },
      "required": ["uid", "email", "role", "isActive", "isUpgraded", "anonymousName"]
    },
    "Question": {
      "title": "Question",
      "description": "Exam question with 5 alternatives",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctOption": { "type": "integer" },
        "category": { "type": "string" },
        "law": { "type": "string" },
        "difficulty": { "type": "integer", "description": "Difficulty level from 1 to 5 stars" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "options", "correctOption"]
    },
    "SimulationResult": {
      "title": "Simulation Result",
      "description": "Result of a completed simulation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "date": { "type": "string", "format": "date-time" },
        "anonymousName": { "type": "string" }
      },
      "required": ["userId", "score", "totalQuestions", "date", "anonymousName"]
    },
    "ActiveSimulation": {
      "title": "Active Simulation",
      "description": "State of a simulation in progress",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questions": { "type": "array" },
        "currentIndex": { "type": "integer" },
        "answers": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "questions", "currentIndex", "answers"]
    },
    "QuestionError": {
      "title": "Question Error",
      "description": "Report of an error in a question",
      "type": "object",
      "properties": {
        "questionId": { "type": "string" },
        "questionText": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["questionId", "questionText", "userId", "userEmail", "description", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "MindMap": {
      "title": "Mind Map",
      "description": "Visual summary for study",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "content": { "type": "string", "description": "HTML content" },
        "questionNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "content", "createdAt"]
    },
    "CutoffPoll": {
      "title": "Cutoff Poll",
      "description": "User opinion on cutoff score",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "score", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Bank of questions"
    },
    "/simulations/{simulationId}": {
      "schema": "SimulationResult",
      "description": "History of simulations"
    },
    "/active_simulations/{userId}": {
      "schema": "ActiveSimulation",
      "description": "Current active simulation for a user"
    },
    "/question_errors/{errorId}": {
      "schema": "QuestionError",
      "description": "Reports of errors in questions"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/mind_maps/{mapId}": {
      "schema": "MindMap",
      "description": "Study mind maps"
    },
    "/cutoff_polls/{pollId}": {
      "schema": "CutoffPoll",
      "description": "User votes for cutoff score"
    }
  }
}
